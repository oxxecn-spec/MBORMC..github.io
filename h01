        <ul class="nav-links" id="navLinks">
            <li><a href="https://www.insectscreen.cc/">Home</a></li>
            <li><a href="https://www.insectscreen.cc/#products">DIY Screens</a></li>
            <li><a href="https://www.insectscreen.cc/#about">About</a></li>
