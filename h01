        </ul>
        <a href="https://wa.me/8613536600067" class="btn btn-dark" target="_blank" rel="noopener">📱 WhatsApp</a>
    </div>
</nav>

<!-- 产品详情内容（示例替换） -->
<section class="product-detail">
    <div class="container">
        <div class="product-detail-grid">
            <!-- 左侧图片区 -->
            <div class="product-gallery">
                <img src="https://raw.githubusercontent.com/oxxecn-spec/MBORMC..github.io/refs/heads/main/jpg/h01.jpg" alt="Retractable Roll-Up Screen">
            </div>
            <!-- 右侧信息区 -->
            <div class="product-info">
                <h1>Retractable Roll-Up Screen</h1>
                <div class="product-price">Quote by size (from £45 / AU$85 for window)</div>
                <div class="product-meta">
                    <p><strong>DIY Badge:</strong> 🔧 DIY in 10 mins</p>
